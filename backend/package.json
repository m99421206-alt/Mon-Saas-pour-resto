{
  "name": "africamenu-backend",
  "version": "0.1.0",
  "private": true,
  "description": "API AfricaMenu (Express + MySQL)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:schema": "node scripts/init-db.js",
    "db:settings": "node scripts/migrate-restaurant-settings.js",
    "db:admin-timestamps": "node scripts/migrate-admin-timestamps.js",
    "db:audit-log": "node scripts/migrate-audit-log.js",
    "db:user-status": "node scripts/migrate-user-account-status.js",
    "db:admin-restaurants": "node scripts/migrate-admin-restaurants.js",
    "db:admin-subscriptions": "node scripts/migrate-admin-subscriptions.js",
    "db:admin-platform-settings": "node scripts/migrate-admin-platform-settings.js",
    "db:subscription-plan-key": "node scripts/migrate-subscription-plan-key.js",
    "db:onboarding": "node scripts/migrate-onboarding-flags.js",
    "db:registration-fields": "node scripts/migrate-registration-fields.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0"
  }
}
