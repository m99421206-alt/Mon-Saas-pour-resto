# AfricaMenu — variables d'environnement (copier vers .env)
# cp .env.example .env   puis renseigner les valeurs

# --- Environnement ---
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# --- MySQL ---
DB_HOST=127.0.0.1
DB_USER=
DB_PASSWORD=
DB_NAME=AfricaMenu
DB_CONNECTION_LIMIT=10

# --- Authentification ---
# Générer une clé longue aléatoire (32 caractères minimum en production, ex. openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# --- Administration plateforme ---
# Emails autorisés sur /api/admin/* (séparés par des virgules)
# OBLIGATOIRE en production (NODE_ENV=production)
ADMIN_EMAILS=admin@votredomaine.com
# Durée du token temporaire quand un admin ouvre le dashboard d'un restaurant
ADMIN_DASHBOARD_ACCESS_EXPIRES_IN=30m

# --- CORS ---
# URL exacte du frontend (sans slash final). Plusieurs origines : séparer par des virgules.
# Ex. https://app.africamenu.com ou http://localhost:5500 en dev
CORS_ORIGIN=http://localhost:5500

# --- Connexion (anti brute-force) ---
# Nombre d'échecs avant blocage temporaire (par email + IP)
LOGIN_MAX_ATTEMPTS=5
# Durée du blocage en minutes
LOGIN_LOCKOUT_MINUTES=15

# --- Affichage console au démarrage ---
LAN_URL=http://localhost:4000

# --- Sauvegardes automatiques (npm run backup) ---
# Dossier de sortie (relatif a backend/ ou chemin absolu)
BACKUP_DIR=../backups
# Nombre de jours avant suppression des anciennes sauvegardes
BACKUP_RETENTION_DAYS=14
# Optionnel : chemin complet si mysqldump n'est pas dans le PATH (Windows)
# MYSQLDUMP_PATH=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysqldump.exe
# MYSQL_PATH=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysql.exe

# --- Abonnements (migration optionnelle) ---
TRIAL_BACKFILL_DAYS=14
