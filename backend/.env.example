# Copier ce fichier vers .env et adapter les valeurs (ne pas committer .env)

PORT=4000

# Origines autorisées pour CORS, séparées par des virgules.
# En dev, si CORS_ORIGIN est vide, le serveur autorise automatiquement les origines http sur le port 5500.
# Exemple local : CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500,http://192.168.100.16:5500
# Exemple production : CORS_ORIGIN=https://votre-domaine.com
CORS_ORIGIN=

# MySQL — créer la base une fois si besoin :
# CREATE DATABASE africamenu CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# Puis appliquer les tables : npm run db:schema

# Puis : npm run db:admin-timestamps  (colonnes created_at users/products)
# Puis : npm run db:audit-log        (table audit_logs — journal admin)
# Puis : npm run db:user-status     (colonnes users.account_status)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=africamenu

# Optionnel — nombre max de connexions dans le pool
# DB_CONNECTION_LIMIT=10

# Étape 5+ — JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Administration plateforme — emails autorisés pour GET /api/admin/* (séparés par des virgules).
# Vide = tout utilisateur connecté peut appeler l’API admin (à éviter en production).
ADMIN_EMAILS=
# BCRYPT_SALT_ROUNDS=10

# Route protégée exemple (étape 6) : GET /api/me avec header Authorization: Bearer <token>
# Étape 7 — CRUD catégories (JWT) : GET/POST /api/categories, PUT/DELETE /api/categories/:id
# Étape 8 — CRUD produits (JWT) : GET/POST /api/products, PUT/DELETE /api/products/:id
# Étape 9 — menu public (sans JWT) : GET /menu/:restaurantId
