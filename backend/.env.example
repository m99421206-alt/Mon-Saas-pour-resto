# Copier ce fichier vers .env et adapter les valeurs (ne pas committer .env)

PORT=4000

# Origine autorisée pour CORS (ex. http://127.0.0.1:5500 ou URL du front déployé)
# Laisser vide ou mettre * en dev : le serveur utilise `true` (toutes origines) si absent
CORS_ORIGIN=

# MySQL — créer la base une fois si besoin :
# CREATE DATABASE africamenu CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# Puis appliquer les tables : npm run db:schema

DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=africamenu

# Optionnel — nombre max de connexions dans le pool
# DB_CONNECTION_LIMIT=10

# Étape 5+ — JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
# BCRYPT_SALT_ROUNDS=10

# Route protégée exemple (étape 6) : GET /api/me avec header Authorization: Bearer <token>
# Étape 7 — CRUD catégories (JWT) : GET/POST /api/categories, PUT/DELETE /api/categories/:id
# Étape 8 — CRUD produits (JWT) : GET/POST /api/products, PUT/DELETE /api/products/:id
# Étape 9 — menu public (sans JWT) : GET /menu/:restaurantId
